icon-pause = Ô££
icon-stop = Ôßö
icon-prev = Ô¶≠
icon-next = Ô¶¨
icon-seekb = 
icon-seekf = 
icon-random = 
icon-repeat = 
icon-repeatone = 
icon-single = 
icon-consume = 

